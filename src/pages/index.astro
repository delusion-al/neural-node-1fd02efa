---
import Layout from '../layouts/Layout.astro';
---
<Layout>
    <main class="container">
        <!-- HERO SECTION -->
        <section class="hero">
            <h1 class="kinetic-text">Architecting <span class="gradient-text">Digital Luxury.</span></h1>
            <p class="hero-subtitle">Precision-engineered lead generation systems for high-ticket enterprises.</p>
            <div class="hero-cta-group">
                <a href="/auth/signup" class="btn-primary">Get Started Now</a>
                <a href="/events/booking" class="btn-secondary">Book a Strategy Call</a>
            </div>
        </section>

        <!-- BENTO GRID -->
        <section class="bento-grid">
            <div class="bento-item large glass-card">
                <div class="content">
                    <h3>Core Intelligence</h3>
                    <p>Our spatial UI logic increases engagement by 40% through intentional visual hierarchy.</p>
                </div>
                <div class="visual-demo">[Interactive Component Placeholder]</div>
            </div>
            
            <div class="bento-item medium glass-card">
                <h3>Rapid Auth</h3>
                <p>One-tap Google integration for zero-friction onboarding.</p>
                <div class="icon-pulse"></div>
            </div>

            <div class="bento-item medium glass-card">
                <h3>Event Sync</h3>
                <p>Real-time booking integrated directly into your CRM.</p>
                <div class="icon-pulse" style="background: var(--color-mint)"></div>
            </div>

            <div class="bento-item small glass-card">
                <span class="metric">99.9%</span>
                <span class="label">Uptime Efficiency</span>
            </div>

            <div class="bento-item small glass-card">
                <span class="metric">12.4x</span>
                <span class="label">Lead Velocity</span>
            </div>

            <div class="bento-item medium glass-card">
                <h3>Admin Control</h3>
                <p>Full visibility over your lead pipeline in one dashboard.</p>
            </div>
        </section>

        <!-- LEAD GEN SECTION -->
        <section class="conversion-zone">
            <div class="glass-card lead-form-container">
                <h2>Ready to scale?</h2>
                <p>Enter your details to receive a custom structural audit.</p>
                <form class="lead-form">
                    <input type="email" placeholder="Enter your corporate email" required />
                    <button type="submit" class="btn-primary">Request Access</button>
                </form>
            </div>
        </section>
    </main>

    <style>
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        .hero {
            height: 90vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .kinetic-text {
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            letter-spacing: -0.03em;
        }

        .gradient-text {
            background: linear-gradient(to right, var(--color-pulse), var(--color-mint));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-subtitle {
            font-size: 1.25rem;
            color: rgba(255, 255, 255, 0.6);
            max-width: 600px;
            margin-bottom: 3rem;
        }

        .btn-primary {
            background: var(--color-pulse);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 100px;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
            box-shadow: 0 0 20px hsla(263, 90%, 60%, 0.4);
        }

        .btn-primary:hover {
            transform: scale(1.05);
            box-shadow: 0 0 30px hsla(263, 90%, 60%, 0.6);
        }

        .btn-secondary {
            margin-left: 1rem;
            color: white;
            padding: 1rem 2.5rem;
            border: 1px solid var(--glass-border);
            border-radius: 100px;
            text-decoration: none;
            backdrop-filter: blur(10px);
            transition: 0.3s;
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .bento-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-auto-rows: 200px;
            gap: 1.5rem;
            margin-bottom: 10rem;
        }

        .bento-item {
            padding: 2rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .large {
            grid-column: span 2;
            grid-row: span 2;
        }

        .medium {
            grid-column: span 1;
            grid-row: span 1;
        }

        .small {
            grid-column: span 1;
            grid-row: span 1;
            align-items: center;
            text-align: center;
        }

        .metric {
            font-size: 2.5rem;
            font-weight: 800;
            display: block;
            color: var(--color-mint);
        }

        .label {
            font-size: 0.9rem;
            opacity: 0.6;
        }

        .conversion-zone {
            display: flex;
            justify-content: center;
            margin-bottom: 10rem;
        }

        .lead-form-container {
            width: 100%;
            max-width: 600px;
            padding: 4rem;
            text-align: center;
        }

        .lead-form {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
        }

        .lead-form input {
            flex: 1;
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--glass-border);
            padding: 1rem;
            border-radius: 12px;
            color: white;
            outline: none;
        }

        .icon-pulse {
            width: 12px;
            height: 12px;
            background: var(--color-pulse);
            border-radius: 50%;
            margin-top: 1rem;
            box-shadow: 0 0 10px var(--color-pulse);
            animation: blink 2s infinite;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        @media (max-width: 768px) {
            .bento-grid {
                grid-template-columns: repeat(1, 1fr);
                grid-auto-rows: auto;
            }
            .large, .medium, .small {
                grid-column: span 1;
                grid-row: span 1;
            }
            .lead-form {
                flex-direction: column;
            }
        }
    </style>
</Layout>